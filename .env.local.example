# Copy to `.env.local` and adjust values for your local test.

ENVIRONMENT=development
DEBUG=true
WORKERS=4
OBSERVABILITY__LOG_LEVEL=INFO
OBSERVABILITY__LOG_FORMAT=json

# Admin control-plane
ADMIN_API_KEY=changeme-admin-key
ADMIN_READ_API_KEYS=
ADMIN_WRITE_API_KEYS=
ADMIN_ALLOWED_IPS=
ADMIN_TRUST_PROXY_HEADERS=true
ADMIN_MAX_WRITE_ACTIONS_PER_MINUTE=120
ADMIN_DEFAULT_KEY_TTL_SECONDS=0

# Route plugin secrets consumed via config/routes.yaml placeholders
OAG_USER_JWT_SECRET=dev-user-jwt-secret
OAG_CHAT_JWT_SECRET=dev-chat-jwt-secret
OAG_ORDER_API_KEY_1=sk-test-key-12345678
OAG_ORDER_API_KEY_2=sk-prod-key-87654321
